{% comment %}
  MNW — Global Header
  - Transparent on hero, transitions to near-black at 60px scroll
  - Desktop: MNW wordmark left / nav links right
  - Mobile: full-screen overlay with hamburger toggle
{% endcomment %}

<header class="site-header" role="banner">
  <div class="site-header__inner container">

    <!-- Logo / Wordmark -->
    <a class="site-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      MNW
    </a>

    <!-- Desktop nav -->
    <nav class="site-header__nav" role="navigation" aria-label="Main navigation">
      <a class="site-header__nav-link" href="{{ routes.all_products_collection_url }}">Shop</a>
      <a class="site-header__nav-link" href="{{ routes.root_url }}pages/fitment-guide">Fitment Guide</a>
      <a class="site-header__nav-link" href="{{ routes.root_url }}pages/about">About</a>
      <a class="site-header__nav-link" href="{{ routes.root_url }}pages/contact">Contact</a>
    </nav>

    <!-- Mobile toggle -->
    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="nav-overlay"
      aria-label="Open navigation"
    >
      <span class="nav-toggle__line">—</span>
      <span class="nav-toggle__line">—</span>
      <span class="nav-toggle__line">—</span>
    </button>

  </div>
</header>

<!-- Mobile full-screen overlay -->
<div class="nav-overlay" id="nav-overlay" role="dialog" aria-modal="true" aria-label="Navigation">
  <button class="nav-overlay__close" aria-label="Close navigation">&times;</button>
  <nav class="nav-overlay__nav">
    <a class="nav-overlay__link" href="{{ routes.all_products_collection_url }}">Shop</a>
    <a class="nav-overlay__link" href="{{ routes.root_url }}pages/fitment-guide">Fitment Guide</a>
    <a class="nav-overlay__link" href="{{ routes.root_url }}pages/about">About</a>
    <a class="nav-overlay__link" href="{{ routes.root_url }}pages/contact">Contact</a>
    <a class="nav-overlay__link" href="{{ routes.root_url }}pages/faq">FAQ</a>
  </nav>
  <div class="nav-overlay__footer">
    <span class="label">MNW &mdash; Brisbane, Australia</span>
  </div>
</div>

{% stylesheet %}
/* ── Site Header ── */
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 28px 0;
  transition:
    background var(--duration-hover) var(--ease-precision),
    padding var(--duration-hover) var(--ease-precision),
    border-color var(--duration-hover) var(--ease-precision);
  border-bottom: 1px solid transparent;
}

body.template-index .site-header {
  opacity: 0;
  transform: translateY(-10px);
  pointer-events: none;
}

body.template-index .site-header.is-ready {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.site-header.is-scrolled {
  background: rgba(10, 10, 10, 0.95);
  padding: 18px 0;
  border-bottom-color: var(--rule);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.site-header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Logo */
.site-header__logo {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 15px;
  letter-spacing: 0.2em;
  color: var(--accent);
  text-transform: uppercase;
  text-decoration: none;
  line-height: 1;
}

/* Desktop nav */
.site-header__nav {
  display: flex;
  align-items: center;
  gap: 36px;
}

.site-header__nav-link {
  position: relative;
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 12px;
  letter-spacing: 0.3em;
  color: var(--text-secondary);
  text-transform: uppercase;
  text-decoration: none;
  transition: color var(--duration-hover) var(--ease-precision);
}

.site-header__nav-link::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--text-secondary);
  transition: width 250ms var(--ease-precision);
}

.site-header__nav-link:hover {
  color: var(--text-primary);
}

.site-header__nav-link:hover::after {
  width: 100%;
}

/* Mobile toggle */
.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}

.nav-toggle__line {
  font-family: var(--font-body);
  font-size: 11px;
  letter-spacing: 0.5em;
  color: var(--text-secondary);
  line-height: 1;
  display: block;
}

/* ── Mobile overlay ── */
.nav-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: var(--bg-deep);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 60px var(--section-pad-h);
  opacity: 0;
  pointer-events: none;
  transform: translateY(-12px);
  transition:
    opacity 350ms var(--ease-precision),
    transform 350ms var(--ease-precision);
}

.nav-overlay.is-open {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}

.nav-overlay__close {
  position: absolute;
  top: 28px;
  right: var(--section-pad-h);
  font-size: 28px;
  color: var(--text-secondary);
  background: none;
  border: none;
  cursor: pointer;
  line-height: 1;
  transition: color var(--duration-hover);
}

.nav-overlay__close:hover {
  color: var(--text-primary);
}

.nav-overlay__nav {
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.nav-overlay__link {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: clamp(28px, 7vw, 48px);
  letter-spacing: 0.05em;
  color: var(--text-secondary);
  text-transform: uppercase;
  text-decoration: none;
  transition: color var(--duration-hover);
}

.nav-overlay__link:hover {
  color: var(--text-primary);
}

.nav-overlay__footer {
  position: absolute;
  bottom: 40px;
  left: var(--section-pad-h);
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .site-header__nav {
    display: none;
  }

  .nav-toggle {
    display: flex;
  }
}
{% endstylesheet %}

