{% comment %}
  MNW — Fitment Guide
  Searchable V1 static data table driven by section blocks.
{% endcomment %}

{% assign marques = 'BMW,Porsche,Audi,Mercedes,Volkswagen' | split: ',' %}

<section class="fitment-guide" aria-labelledby="fitment-guide-heading">
  <div class="fitment-guide__hero container reveal">
    <p class="label fitment-guide__label">Fitment Guide</p>
    <h1 class="heading-xl fitment-guide__title" id="fitment-guide-heading">Built around exact fitment.</h1>
    <p class="fitment-guide__intro body-text">
      Search by make, model, or year to find baseline fitments for MNW forged wheels. Final offsets and clearances are confirmed to order.
    </p>

    <div class="fitment-guide__search-wrap">
      <label class="visually-hidden" for="fitment-guide-search">Search fitment guide</label>
      <input
        class="fitment-guide__search"
        id="fitment-guide-search"
        type="search"
        placeholder="Search by make, model, or year..."
      >
    </div>
  </div>

  <div class="fitment-guide__sections container">
    {% for marque in marques %}
      <section class="fitment-guide__marque" data-marque="{{ marque | downcase }}">
        <div class="fitment-guide__marque-head reveal">
          <p class="label">{{ marque }}</p>
          <h2 class="heading-md fitment-guide__marque-title">{{ marque }} fitments</h2>
          <p class="body-text fitment-guide__marque-copy">
            {% case marque %}
              {% when 'BMW' %}
                MNW forged wheels are available for core BMW chassis including E9X, F3X, F8X, G2X, and G8X applications.
              {% when 'Porsche' %}
                Porsche fitments cover 981, 718, 991, 992, and selected Macan and Cayenne applications with chassis-specific offsets.
              {% when 'Audi' %}
                Audi fitments include MQB, B8/B9, and RS applications where spoke clearance and brake package depth matter.
              {% when 'Mercedes' %}
                Mercedes fitments focus on current AMG and core sedan platforms with brake clearance accounted for in the final spec.
              {% when 'Volkswagen' %}
                Volkswagen fitments cover MQB performance platforms and selected larger-body applications.
            {% endcase %}
          </p>
        </div>

        <div class="fitment-guide__table-wrap reveal">
          <table class="fitment-guide__table" aria-label="{{ marque }} fitment table">
            <thead>
              <tr>
                <th>Vehicle</th>
                <th>Recommended Diameter</th>
                <th>Recommended Width</th>
                <th>Offset Range</th>
                <th>PCD</th>
                <th>Centre Bore</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              {% for block in section.blocks %}
                {% if block.settings.make == marque %}
                  <tr
                    class="fitment-guide__row"
                    data-search="{{ block.settings.make | downcase }} {{ block.settings.model | downcase }} {{ block.settings.generation | downcase }} {{ block.settings.year | downcase }} {{ block.settings.notes | downcase }}"
                    {{ block.shopify_attributes }}
                  >
                    <td>
                      <span class="fitment-guide__vehicle">{{ block.settings.model }}</span>
                      {% if block.settings.generation != blank %}
                        <span class="fitment-guide__meta">{{ block.settings.generation }}{% if block.settings.year != blank %} / {{ block.settings.year }}{% endif %}</span>
                      {% elsif block.settings.year != blank %}
                        <span class="fitment-guide__meta">{{ block.settings.year }}</span>
                      {% endif %}
                    </td>
                    <td>{{ block.settings.diameter }}</td>
                    <td>{{ block.settings.width }}</td>
                    <td>{{ block.settings.offset }}</td>
                    <td>{{ block.settings.pcd }}</td>
                    <td>{{ block.settings.centre_bore }}</td>
                    <td>{{ block.settings.notes }}</td>
                  </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        </div>

        <div class="fitment-guide__footer reveal">
          <a class="btn-ghost fitment-guide__browse" href="{{ routes.all_products_collection_url }}?filter_make={{ marque | url_encode }}">
            Browse all {{ marque }} fitments &rarr;
          </a>
        </div>
      </section>
    {% endfor %}
  </div>
</section>

<script>
  (function () {
    const input = document.getElementById('fitment-guide-search');
    if (!input) return;

    const rows = Array.prototype.slice.call(document.querySelectorAll('.fitment-guide__row'));
    const sections = Array.prototype.slice.call(document.querySelectorAll('.fitment-guide__marque'));

    function filterRows() {
      const term = input.value.trim().toLowerCase();

      rows.forEach(function (row) {
        const matches = term === '' || row.dataset.search.indexOf(term) !== -1;
        row.hidden = !matches;
      });

      sections.forEach(function (section) {
        const visibleRows = section.querySelectorAll('.fitment-guide__row:not([hidden])').length;
        section.hidden = visibleRows === 0 && term !== '';
      });
    }

    input.addEventListener('input', filterRows);
  })();
</script>

{% stylesheet %}
.fitment-guide {
  background: var(--bg-dark);
  padding: 140px 0 var(--section-pad-v);
}

.fitment-guide__hero {
  margin-bottom: 56px;
}

.fitment-guide__label {
  margin-bottom: 18px;
}

.fitment-guide__title {
  max-width: 920px;
  margin-bottom: 24px;
}

.fitment-guide__intro {
  max-width: 680px;
}

.fitment-guide__search-wrap {
  margin-top: 36px;
  max-width: 560px;
}

.fitment-guide__search {
  width: 100%;
  background: transparent;
  border: 1px solid var(--rule);
  border-bottom-color: rgba(245, 245, 243, 0.32);
  color: var(--text-primary);
  font-family: var(--font-body);
  font-size: 13px;
  letter-spacing: 0.12em;
  padding: 16px 18px;
}

.fitment-guide__search::placeholder {
  color: var(--text-muted);
}

.fitment-guide__sections {
  display: grid;
  gap: 72px;
}

.fitment-guide__marque-head {
  margin-bottom: 24px;
}

.fitment-guide__marque-title {
  margin: 14px 0 14px;
}

.fitment-guide__marque-copy {
  max-width: 720px;
}

.fitment-guide__table-wrap {
  overflow-x: auto;
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
}

.fitment-guide__table {
  width: 100%;
  border-collapse: collapse;
  min-width: 920px;
}

.fitment-guide__table th,
.fitment-guide__table td {
  padding: 18px 12px;
  text-align: left;
  border-bottom: 1px solid var(--rule);
}

.fitment-guide__table th {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 10px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.fitment-guide__table td {
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--text-secondary);
}

.fitment-guide__vehicle {
  display: block;
  font-family: var(--font-heading);
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.03em;
  color: var(--text-primary);
}

.fitment-guide__meta {
  display: block;
  margin-top: 4px;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.fitment-guide__footer {
  margin-top: 24px;
}

.fitment-guide__browse {
  display: inline-block;
}

@media (max-width: 768px) {
  .fitment-guide {
    padding-top: 110px;
  }

  .fitment-guide__sections {
    gap: 56px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Fitment Guide",
  "settings": [],
  "blocks": [
    {
      "type": "fitment",
      "name": "Fitment Row",
      "settings": [
        {
          "type": "select",
          "id": "make",
          "label": "Make",
          "options": [
            { "value": "BMW", "label": "BMW" },
            { "value": "Porsche", "label": "Porsche" },
            { "value": "Audi", "label": "Audi" },
            { "value": "Mercedes", "label": "Mercedes" },
            { "value": "Volkswagen", "label": "Volkswagen" }
          ],
          "default": "BMW"
        },
        { "type": "text", "id": "model", "label": "Model", "default": "M3" },
        { "type": "text", "id": "generation", "label": "Generation", "default": "G80" },
        { "type": "text", "id": "year", "label": "Year range", "default": "2021+" },
        { "type": "text", "id": "diameter", "label": "Recommended diameter", "default": "19 / 20\"" },
        { "type": "text", "id": "width", "label": "Recommended width", "default": "19x9.5 / 20x10.5" },
        { "type": "text", "id": "offset", "label": "Offset range", "default": "ET20-ET35" },
        { "type": "text", "id": "pcd", "label": "PCD", "default": "5x112" },
        { "type": "text", "id": "centre_bore", "label": "Centre bore", "default": "66.6" },
        { "type": "text", "id": "notes", "label": "Notes", "default": "Rear fitment should be confirmed against tyre choice." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fitment Guide"
    }
  ]
}
{% endschema %}