{% comment %}
  MNW — Social Proof Gallery (Section 8)
  "MNW IN THE WILD" — masonry grid of customer car images.
  On hover: white overlay with customer name / car / wheel info.
  Up to 12 manual image blocks.
{% endcomment %}

<section class="gallery" aria-labelledby="gallery-heading">

  <div class="gallery__header container">
    <p class="label gallery__label" id="gallery-heading">MNW In The Wild</p>
  </div>

  <div class="gallery__grid" role="list">
    {% for block in section.blocks %}
      {% if block.type == 'image' %}
        <div
          class="gallery__item reveal"
          role="listitem"
          style="--delay: {{ forloop.index0 | times: 60 }}ms"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag:
              loading: 'lazy',
              class: 'gallery__img',
              alt: block.settings.customer_name | default: 'MNW customer'
            }}
          {% else %}
            <div class="gallery__img-placeholder" aria-hidden="true"></div>
          {% endif %}

          <div class="gallery__overlay" aria-hidden="true">
            <div class="gallery__overlay-text">
              {% if block.settings.customer_name != blank %}
                <span class="gallery__customer">{{ block.settings.customer_name }}</span>
              {% endif %}
              {% if block.settings.car != blank %}
                <span class="gallery__sep">&nbsp;&middot;&nbsp;</span>
                <span class="gallery__car">{{ block.settings.car }}</span>
              {% endif %}
              {% if block.settings.wheel != blank %}
                <span class="gallery__sep">&nbsp;&middot;&nbsp;</span>
                <span class="gallery__wheel-info">{{ block.settings.wheel }}</span>
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}

    <!-- Placeholder tiles if no blocks added -->
    {% if section.blocks.size == 0 %}
      {% for i in (1..6) %}
        <div class="gallery__item gallery__item--placeholder reveal" role="listitem" style="--delay: {{ forloop.index0 | times: 60 }}ms">
          <div class="gallery__img-placeholder" aria-hidden="true"></div>
          <div class="gallery__overlay" aria-hidden="true">
            <div class="gallery__overlay-text">
              <span class="gallery__customer">Your Car Here</span>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>

  <!-- Instagram link -->
  {% if section.settings.instagram_handle != blank %}
    <div class="gallery__footer container">
      <a
        class="gallery__instagram-link"
        href="https://instagram.com/{{ section.settings.instagram_handle | remove: '@' }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="MNW on Instagram"
      >
        @{{ section.settings.instagram_handle | remove: '@' }} on Instagram &rarr;
      </a>
    </div>
  {% endif %}

</section>

{% stylesheet %}
.gallery {
  background: var(--bg-dark);
  padding-bottom: var(--section-pad-v);
  padding-top: calc(var(--section-pad-v) * 0.75);
}

.gallery__header {
  margin-bottom: 40px;
}

.gallery__label {
  text-align: center;
}

/* Masonry-style grid */
.gallery__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-auto-rows: 300px;
  gap: 2px;
}

/* Vary heights for masonry feel */
.gallery__item:nth-child(3n+1) { grid-row: span 2; }
.gallery__item:nth-child(5n+2) { grid-row: span 1; }

.gallery__item {
  position: relative;
  overflow: hidden;
  background: var(--bg-surface);
  transition-delay: var(--delay, 0ms);
}

.gallery__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 400ms var(--ease-precision);
}

.gallery__img-placeholder {
  width: 100%;
  height: 100%;
  background: var(--bg-surface);
  background-image: repeating-linear-gradient(
    -45deg,
    transparent,
    transparent 10px,
    rgba(255,255,255,0.01) 10px,
    rgba(255,255,255,0.01) 20px
  );
}

/* Hover overlay */
.gallery__overlay {
  position: absolute;
  inset: 0;
  background: rgba(245, 245, 243, 0.08);
  display: flex;
  align-items: flex-end;
  padding: 20px;
  opacity: 0;
  transition: opacity 300ms var(--ease-precision);
  backdrop-filter: blur(0px);
}

.gallery__item:hover .gallery__overlay {
  opacity: 1;
}

.gallery__item:hover .gallery__img {
  transform: scale(1.03);
}

.gallery__overlay-text {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 11px;
  letter-spacing: 0.2em;
  color: var(--text-primary);
  text-transform: uppercase;
  line-height: 1.4;
}

.gallery__sep {
  color: var(--text-muted);
}

/* Instagram link */
.gallery__footer {
  margin-top: 48px;
  text-align: center;
}

.gallery__instagram-link {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 12px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--text-muted);
  text-decoration: none;
  border-bottom: 1px solid rgba(122, 122, 120, 0.3);
  padding-bottom: 2px;
  transition: color var(--duration-hover) var(--ease-precision);
}

.gallery__instagram-link:hover {
  color: var(--text-primary);
}

/* ── Mobile ── */
@media (max-width: 768px) {
  .gallery__grid {
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 220px;
  }

  .gallery__item:nth-child(3n+1) { grid-row: span 1; }
}

@media (max-width: 480px) {
  .gallery__grid {
    grid-template-columns: 1fr;
    grid-auto-rows: 280px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Gallery — MNW in the Wild",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "instagram_handle",
      "label": "Instagram handle",
      "default": "mnwwheels",
      "placeholder": "mnwwheels"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Customer Car",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Car photo"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer name",
          "placeholder": "Alex M."
        },
        {
          "type": "text",
          "id": "car",
          "label": "Car",
          "placeholder": "BMW M3 G80"
        },
        {
          "type": "text",
          "id": "wheel",
          "label": "Wheel / Finish",
          "placeholder": "MNW-01 / Brushed Silver"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
