{% comment %}
  MNW — Default Page Section
  Minimal dark editorial layout for FAQ, shipping, policy-adjacent content pages.
{% endcomment %}

<section class="page-main" aria-labelledby="page-main-heading">
  <div class="page-main__inner container reveal">
    <p class="label page-main__label">MNW</p>
    <h1 class="heading-lg page-main__title" id="page-main-heading">{{ page.title }}</h1>

    {% if page.content != blank %}
      <div class="page-main__content body-text rte">
        {{ page.content }}
      </div>
    {% else %}
      <div class="page-main__content body-text">
        <p>Add content to this page in Shopify admin to publish it.</p>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
.page-main {
  background: var(--bg-dark);
  min-height: 100vh;
  padding: 140px 0 var(--section-pad-v);
}

.page-main__inner {
  max-width: 820px;
}

.page-main__label {
  margin-bottom: 18px;
}

.page-main__title {
  margin-bottom: 28px;
}

.page-main__content {
  max-width: 720px;
}

.page-main__content p + p,
.page-main__content ul + p,
.page-main__content h2 + p,
.page-main__content h3 + p {
  margin-top: 18px;
}

.page-main__content h2,
.page-main__content h3 {
  font-family: var(--font-heading);
  color: var(--text-primary);
  letter-spacing: 0.03em;
  line-height: 1.15;
}

.page-main__content h2 {
  font-size: clamp(24px, 3vw, 32px);
  margin-top: 36px;
}

.page-main__content h3 {
  font-size: clamp(18px, 2vw, 22px);
  margin-top: 28px;
}

.page-main__content a {
  text-decoration: underline;
  text-decoration-color: rgba(175, 175, 173, 0.4);
  text-underline-offset: 3px;
}

.page-main__content ul {
  display: grid;
  gap: 12px;
  margin-top: 18px;
}

@media (max-width: 768px) {
  .page-main {
    padding-top: 110px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Page Main",
  "settings": []
}
{% endschema %}