{% comment %}
  MNW — Configurator CTA Section (v2)
  Dark background — consistent with brand palette.
  Vehicle selector: Make → Model → Year → "See Available Fitments →"
{% endcomment %}

<section class="configurator-cta" aria-labelledby="configurator-heading">
  <div class="container">

    <div class="configurator-cta__content reveal">

      <span class="configurator-cta__pre-rule" aria-hidden="true"></span>
      <p class="label configurator-cta__label">Custom Build Brief</p>

      <h2 class="configurator-cta__heading" id="configurator-heading">
        {{ section.settings.heading | default: 'Start from the car, not the shelf.' }}
      </h2>

      <p class="configurator-cta__sub">
        {{ section.settings.subheadline | default: "Select your vehicle and we'll spec the wheel around it. Face design, fitment, finish, and brake clearance are resolved as one custom package." }}
      </p>

      <!-- Vehicle selector -->
      <form class="configurator-cta__form" role="search" aria-label="Find fitments for your vehicle">

        <div class="configurator-cta__selects">

          <div class="configurator-cta__select-wrap">
            <label class="visually-hidden" for="vehicle-make">Make</label>
            <select class="configurator-cta__select" id="vehicle-make" name="make">
              <option value="">Make</option>
              <option value="BMW">BMW</option>
              <option value="Porsche">Porsche</option>
              <option value="Audi">Audi</option>
              <option value="Mercedes">Mercedes</option>
              <option value="Volkswagen">Volkswagen</option>
              <option value="Other">Other</option>
            </select>
            <span class="configurator-cta__select-arrow" aria-hidden="true">
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="#7A7A78" stroke-width="1" stroke-linecap="square"/></svg>
            </span>
          </div>

          <div class="configurator-cta__select-wrap">
            <label class="visually-hidden" for="vehicle-model">Model</label>
            <select class="configurator-cta__select" id="vehicle-model" name="model" disabled>
              <option value="">Model</option>
            </select>
            <span class="configurator-cta__select-arrow" aria-hidden="true">
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="#7A7A78" stroke-width="1" stroke-linecap="square"/></svg>
            </span>
          </div>

          <div class="configurator-cta__select-wrap">
            <label class="visually-hidden" for="vehicle-year">Year</label>
            <select class="configurator-cta__select" id="vehicle-year" name="year" disabled>
              <option value="">Year</option>
            </select>
            <span class="configurator-cta__select-arrow" aria-hidden="true">
              <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="#7A7A78" stroke-width="1" stroke-linecap="square"/></svg>
            </span>
          </div>

        </div>

        <a
          class="btn-ghost configurator-cta__btn"
          href="{{ routes.all_products_collection_url }}"
          id="configurator-cta-btn"
          aria-disabled="true"
        >
          Start Your Build &rarr;
        </a>

      </form>

      <p class="configurator-cta__not-found">
        Can't find your car?&ensp;
        <a class="configurator-cta__contact-link" href="{{ routes.root_url }}pages/contact">
          Send us your brief &rarr;
        </a>
      </p>

    </div>

  </div>
</section>

{% stylesheet %}
.configurator-cta {
  background: var(--bg-deep);
  padding: var(--section-pad-v) 0;
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
}

.configurator-cta__content {
  max-width: 680px;
  margin-inline: auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

/* Thin rule above label */
.configurator-cta__pre-rule {
  display: block;
  width: 32px;
  height: 1px;
  background: var(--rule);
  margin-bottom: 20px;
}

.configurator-cta__label {
  margin-bottom: 20px;
}

.configurator-cta__heading {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: clamp(36px, 5.5vw, 72px);
  letter-spacing: 0.02em;
  line-height: 1.0;
  color: var(--text-primary);
  margin-bottom: 20px;
}

.configurator-cta__sub {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: clamp(14px, 1.3vw, 17px);
  letter-spacing: 0.02em;
  color: var(--text-secondary);
  max-width: 480px;
  line-height: 1.7;
  margin-bottom: 40px;
}

/* Selector form */
.configurator-cta__form {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.configurator-cta__selects {
  display: flex;
  gap: 1px;
  width: 100%;
  max-width: 600px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.configurator-cta__select-wrap {
  flex: 1;
  position: relative;
  background: var(--bg-dark);
}

.configurator-cta__select {
  width: 100%;
  appearance: none;
  -webkit-appearance: none;
  background: transparent;
  border: none;
  padding: 16px 36px 16px 18px;
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 12px;
  letter-spacing: 0.1em;
  color: var(--text-secondary);
  cursor: pointer;
  transition: background var(--duration-hover) var(--ease-precision),
              color var(--duration-hover) var(--ease-precision);
}

.configurator-cta__select:focus {
  outline: none;
  background: var(--bg-surface);
  color: var(--text-primary);
}

.configurator-cta__select:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

.configurator-cta__select option {
  color: var(--text-primary);
  background: var(--bg-dark);
}

.configurator-cta__select-arrow {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  user-select: none;
  display: flex;
  align-items: center;
}

/* CTA */
.configurator-cta__btn {
  margin-top: 4px;
}

.configurator-cta__btn[aria-disabled="true"] {
  opacity: 0.35;
  pointer-events: none;
}

.configurator-cta__btn.is-active {
  opacity: 1;
  pointer-events: all;
}

/* Footer note */
.configurator-cta__not-found {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 12px;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  margin-top: 24px;
}

.configurator-cta__contact-link {
  color: var(--text-secondary);
  text-decoration: none;
  border-bottom: 1px solid rgba(175, 175, 173, 0.25);
  padding-bottom: 1px;
  transition: color var(--duration-hover) var(--ease-precision),
              border-color var(--duration-hover) var(--ease-precision);
}

.configurator-cta__contact-link:hover {
  color: var(--text-primary);
  border-bottom-color: rgba(245, 245, 243, 0.4);
}

/* ── Mobile ── */
@media (max-width: 640px) {
  .configurator-cta__selects {
    flex-direction: column;
    gap: 1px;
  }

  .configurator-cta__btn {
    width: 100%;
    text-align: center;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Configurator CTA",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Start from the car, not the shelf."
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Select your vehicle and we'll spec the wheel around it. Face design, fitment, finish, and brake clearance are resolved as one custom package."
    }
  ],
  "presets": [{ "name": "Configurator CTA" }]
}
{% endschema %}
