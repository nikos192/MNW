{% comment %}
  MNW — Product Introduction Section (v2)
  Two-column 50/50: left full-bleed wheel image, right text block.
  Added: thin rule above overline, spec list, tighter proportions.
{% endcomment %}

<section class="product-intro" aria-labelledby="product-intro-heading">
  <div class="product-intro__grid">

    <!-- Left: full-bleed image with parallax -->
    <div class="product-intro__image-col">
      {% if section.settings.product_image != blank %}
        {{ section.settings.product_image | image_url: width: 900 | image_tag:
          loading: 'lazy',
          class: 'product-intro__img',
          alt: section.settings.product_image.alt | default: 'MNW forged wheel',
          data-parallax: 'true'
        }}
      {% else %}
        <div class="product-intro__img-placeholder" aria-hidden="true">
          <svg viewBox="0 0 600 700" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;display:block;">
            <rect width="600" height="700" fill="#1A1A18"/>
            <circle cx="300" cy="350" r="220" stroke="#2A2A28" stroke-width="2"/>
            <circle cx="300" cy="350" r="190" stroke="#3A3A38" stroke-width="18"/>
            <path d="M300 350 L300 140" stroke="#4A4A48" stroke-width="22" stroke-linecap="round"/>
            <path d="M300 350 L481 456" stroke="#4A4A48" stroke-width="22" stroke-linecap="round"/>
            <path d="M300 350 L413 558" stroke="#4A4A48" stroke-width="22" stroke-linecap="round"/>
            <path d="M300 350 L187 558" stroke="#4A4A48" stroke-width="22" stroke-linecap="round"/>
            <path d="M300 350 L119 456" stroke="#4A4A48" stroke-width="22" stroke-linecap="round"/>
            <circle cx="300" cy="350" r="40" fill="#1E1E1C" stroke="#3A3A38" stroke-width="2"/>
            <circle cx="300" cy="350" r="16" fill="#2A2A28"/>
            <ellipse cx="220" cy="240" rx="40" ry="24" fill="white" opacity="0.02" transform="rotate(-30 220 240)"/>
          </svg>
        </div>
      {% endif %}
    </div>

    <!-- Right: text block -->
    <div class="product-intro__text-col">
      <div class="product-intro__text-inner reveal">

        <span class="product-intro__pre-rule" aria-hidden="true"></span>

        <p class="label product-intro__overline">
          {{ section.settings.overline | default: 'Series 01 — Forged Monoblock' }}
        </p>

        <h2 class="product-intro__heading" id="product-intro-heading">
          {{ section.settings.heading | default: 'Precision under pressure.' }}
        </h2>

        <p class="body-text product-intro__body">
          {{ section.settings.body | default: "MNW wheels are cold-forged from 6061-T6 aluminium billet. Each set is machined to your vehicle's exact specification — no adapters, no compromise." }}
        </p>

        <ul class="product-intro__specs" aria-label="Key specifications">
          <li class="product-intro__spec-item">
            <span class="product-intro__spec-dot" aria-hidden="true"></span>
            <span>6061-T6 Aluminium Billet</span>
          </li>
          <li class="product-intro__spec-item">
            <span class="product-intro__spec-dot" aria-hidden="true"></span>
            <span>Monoblock Forged Construction</span>
          </li>
          <li class="product-intro__spec-item">
            <span class="product-intro__spec-dot" aria-hidden="true"></span>
            <span>Custom Offset &amp; PCD Per Vehicle</span>
          </li>
        </ul>

        <a
          class="btn-ghost product-intro__cta"
          href="{% if section.settings.cta_url != blank %}{{ section.settings.cta_url }}{% else %}{{ routes.all_products_collection_url }}{% endif %}"
        >
          {{ section.settings.cta_label | default: 'Configure Your Set' }} &rarr;
        </a>

      </div>
    </div>

  </div>
</section>

{% stylesheet %}
.product-intro {
  background: var(--bg-dark);
  overflow: hidden;
}

.product-intro__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 80vh;
}

/* Left: full-bleed */
.product-intro__image-col {
  position: relative;
  overflow: hidden;
  background: var(--bg-surface);
}

.product-intro__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.1s linear;
  will-change: transform;
}

.product-intro__img-placeholder {
  width: 100%;
  height: 100%;
  min-height: 500px;
}

/* Right: text */
.product-intro__text-col {
  display: flex;
  align-items: center;
  padding: var(--section-pad-v) 80px;
  border-left: 1px solid var(--rule);
}

.product-intro__text-inner {
  max-width: 460px;
}

/* Thin rule above overline */
.product-intro__pre-rule {
  display: block;
  width: 32px;
  height: 1px;
  background: var(--rule);
  margin-bottom: 20px;
}

.product-intro__overline {
  margin-bottom: 20px;
}

.product-intro__heading {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: clamp(28px, 3.5vw, 44px);
  letter-spacing: 0.02em;
  line-height: 1.08;
  color: var(--text-primary);
  margin-bottom: 24px;
}

.product-intro__body {
  margin-bottom: 32px;
  max-width: 400px;
}

/* Spec list */
.product-intro__specs {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-bottom: 40px;
  border-top: 1px solid var(--rule);
}

.product-intro__spec-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 11px 0;
  border-bottom: 1px solid var(--rule);
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 12px;
  letter-spacing: 0.12em;
  color: var(--text-secondary);
  text-transform: uppercase;
}

.product-intro__spec-dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--text-muted);
  flex-shrink: 0;
}

.product-intro__cta {
  display: inline-block;
}

/* ── Mobile ── */
@media (max-width: 900px) {
  .product-intro__grid {
    grid-template-columns: 1fr;
    min-height: auto;
  }

  .product-intro__image-col {
    min-height: 56vw;
  }

  .product-intro__text-col {
    padding: 60px var(--section-pad-h);
    border-left: none;
    border-top: 1px solid var(--rule);
  }

  .product-intro__text-inner {
    max-width: 100%;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Product Introduction",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Wheel image",
      "info": "Full-bleed left column. Dark background, studio shot."
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Series 01 — Forged Monoblock"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Precision under pressure."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body copy",
      "default": "MNW wheels are cold-forged from 6061-T6 aluminium billet. Each set is machined to your vehicle's exact specification — no adapters, no compromise."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Configure Your Set"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [{ "name": "Product Introduction" }]
}
{% endschema %}
