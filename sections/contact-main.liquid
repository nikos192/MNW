{% comment %}
  MNW — Contact / Enquiry
{% endcomment %}

<section class="contact-page" aria-labelledby="contact-page-heading">
  <div class="contact-page__layout container">
    <div class="contact-page__intro reveal">
      <p class="label contact-page__label">Custom Enquiry</p>
      <h1 class="heading-lg contact-page__title" id="contact-page-heading">Request a quote.</h1>
      <p class="body-text contact-page__copy">
        Tell us the car, the wheel, and how you want the set built. We’ll confirm fitment, offsets, finish options, and lead time before anything moves forward.
      </p>

      <div class="contact-page__meta">
        <p class="caption">Lead time: 8–12 weeks</p>
        <p class="caption">Made to order</p>
        <p class="caption">No deposit until approval</p>
      </div>
    </div>

    <div class="contact-page__form-wrap reveal">
      {% form 'contact', class: 'contact-page__form' %}
        {% if form.posted_successfully? %}
          <div class="contact-page__success" tabindex="-1">
            <p class="label">Enquiry received</p>
            <p class="body-text">We’ll review your request and come back with fitment guidance and pricing.</p>
          </div>
        {% endif %}

        {{ form.errors | default_errors }}

        <div class="contact-page__fields">
          <div class="contact-page__field">
            <label class="label" for="ContactFormName">Name</label>
            <input id="ContactFormName" type="text" name="contact[name]" value="{{ form.name }}" autocomplete="name">
          </div>

          <div class="contact-page__field">
            <label class="label" for="ContactFormEmail">Email</label>
            <input id="ContactFormEmail" type="email" name="contact[email]" value="{{ form.email }}" autocomplete="email" required>
          </div>

          <div class="contact-page__field">
            <label class="label" for="ContactFormPhone">Phone</label>
            <input id="ContactFormPhone" type="tel" name="contact[phone]" value="{{ form.phone }}" autocomplete="tel">
          </div>

          <div class="contact-page__field">
            <label class="label" for="ContactFormVehicle">Vehicle</label>
            <input id="ContactFormVehicle" type="text" name="contact[Vehicle]" placeholder="BMW M3 G80 / 2023">
          </div>

          <div class="contact-page__field contact-page__field--full">
            <label class="label" for="ContactFormProduct">Wheel / Product</label>
            <input id="ContactFormProduct" type="text" name="contact[Product]" placeholder="MNW-01 / Brushed Silver">
          </div>

          <div class="contact-page__field contact-page__field--full">
            <label class="label" for="ContactFormBody">Project details</label>
            <textarea id="ContactFormBody" name="contact[body]" rows="8" placeholder="Tell us your car, desired wheel size, finish, and any brake or suspension details.">{{ form.body }}</textarea>
          </div>
        </div>

        <button class="btn-solid contact-page__submit" type="submit">Send Enquiry</button>
      {% endform %}
    </div>
  </div>
</section>

<script>
  (function () {
    const params = new URLSearchParams(window.location.search);
    const title = params.get('title');
    const handle = params.get('product');
    const productField = document.getElementById('ContactFormProduct');
    const bodyField = document.getElementById('ContactFormBody');

    if (title && productField && !productField.value) {
      productField.value = title;
    }

    if (handle && bodyField && !bodyField.value) {
      bodyField.value = 'Product: ' + handle + '\n';
    }
  })();
</script>

{% stylesheet %}
.contact-page {
  background: var(--bg-dark);
  min-height: 100vh;
  padding: 140px 0 var(--section-pad-v);
}

.contact-page__layout {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 56px;
  align-items: start;
}

.contact-page__copy {
  max-width: 440px;
  margin-top: 24px;
}

.contact-page__meta {
  display: grid;
  gap: 12px;
  margin-top: 28px;
}

.contact-page__form {
  border-top: 1px solid var(--rule);
  padding-top: 20px;
}

.contact-page__fields {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}

.contact-page__field {
  display: grid;
  gap: 10px;
}

.contact-page__field--full {
  grid-column: 1 / -1;
}

.contact-page__field input,
.contact-page__field textarea {
  width: 100%;
  background: transparent;
  border: 1px solid var(--rule);
  color: var(--text-primary);
  font-family: var(--font-body);
  font-size: 13px;
  letter-spacing: 0.08em;
  padding: 14px 16px;
}

.contact-page__field textarea {
  resize: vertical;
  min-height: 180px;
}

.contact-page__field input:focus,
.contact-page__field textarea:focus {
  outline: none;
  border-color: var(--text-secondary);
}

.contact-page__submit {
  margin-top: 24px;
}

.contact-page__success {
  display: grid;
  gap: 10px;
  margin-bottom: 24px;
}

.contact-page .errors,
.contact-page .form__message {
  margin-bottom: 18px;
  color: var(--text-secondary);
}

@media (max-width: 900px) {
  .contact-page__layout {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  .contact-page {
    padding-top: 110px;
  }

  .contact-page__fields {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Contact Main",
  "settings": []
}
{% endschema %}